---
const year = new Date().getFullYear();

const navLinks = [
  { label: 'Work',     href: '#projects' },
  { label: 'Services', href: '#services' },
  { label: 'About',    href: '#about'    },
  { label: 'Contact',  href: '#contact'  },
];

const services = [
  { label: 'Business Websites', href: '#services' },
  { label: 'Landing Pages',     href: '#services' },
  { label: 'AI Web Tools',      href: '#services' },
  { label: 'SaaS Products',     href: '#services' },
];

const socials = [
  {
    label: 'GitHub',
    href: 'https://github.com/Snehal-Kanzariya',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>`,
  },
  {
    label: 'LinkedIn',
    href: 'https://linkedin.com/in/snehal-kanzariya',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>`,
  },
  {
    label: 'Instagram',
    href: 'https://www.instagram.com/snehal.kanzariya',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>`,
  },
  {
    label: 'Email',
    href: 'mailto:Snehal.kanzariya02@gmail.com',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`,
  },
];
---

<footer class="footer">

  <!-- gradient top rule -->
  <div class="footer-rule" aria-hidden="true"></div>

  <div class="footer-wrap">

    <!-- ══════════ 4-COL GRID ══════════ -->
    <div class="footer-grid">

      <!-- ── Col 1: Brand ── -->
      <div class="col brand-col">

        <a href="/" class="brand-logo" aria-label="Home">
          <span class="logo-mark">SK</span>
          <span class="logo-name">Snehal Kanzariya</span>
        </a>

        <p class="brand-tagline">
          Frontend developer from Rajkot.<br />
          Building websites that make<br />your phone ring.
        </p>

        <!-- availability -->
        <div class="avail-pill">
          <span class="avail-dot" aria-hidden="true"></span>
          Available for projects
        </div>

        <!-- location -->
        <div class="location-row">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
            stroke="#475569" stroke-width="2"
            stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
            <circle cx="12" cy="10" r="3"/>
          </svg>
          Rajkot, Gujarat, India
        </div>

      </div>

      <!-- ── Col 2: Navigation ── -->
      <div class="col links-col">
        <p class="col-label">Navigation</p>
        <nav aria-label="Footer navigation">
          {navLinks.map(l => (
            <a href={l.href} class="footer-link">{l.label}</a>
          ))}
        </nav>
      </div>

      <!-- ── Col 3: Connect (social icons in flex row) ── -->
      <div class="col social-col">
        <p class="col-label">Connect</p>
        <div class="social-row" role="list">
          {socials.map(s => (
            <a
              href={s.href}
              class="social-btn"
              role="listitem"
              target={s.href.startsWith('mailto') ? undefined : '_blank'}
              rel={s.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
              aria-label={s.label}
              title={s.label}
              set:html={s.icon}
            />
          ))}
        </div>
        <!-- email as text link below icons -->
        <a href="mailto:Snehal.kanzariya02@gmail.com" class="email-text-link">
          Snehal.kanzariya02@gmail.com
        </a>
      </div>

      <!-- ── Col 4: CTA card ── -->
      <div class="col cta-col">
        <p class="col-label">Work with me</p>

        <div class="cta-card">
          <div class="card-glow" aria-hidden="true"></div>

          <p class="card-heading">Have a project in mind?</p>
          <p class="card-sub">Let's talk about what you need. Free, no-pressure call.</p>

          <a
            href="https://cal.com/snehal-kanzariya"
            target="_blank"
            rel="noopener noreferrer"
            class="card-btn"
          >
            Book a Call
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="7" y1="17" x2="17" y2="7"/>
              <polyline points="7 7 17 7 17 17"/>
            </svg>
          </a>

          <p class="card-email">
            or&nbsp;
            <a href="mailto:Snehal.kanzariya02@gmail.com" class="email-link">
              send an email
            </a>
          </p>
        </div>
      </div>

    </div><!-- /footer-grid -->

    <!-- ══════════ BOTTOM BAR ══════════ -->
    <div class="footer-bottom">
      <p class="copyright">© {year} Snehal Kanzariya · All rights reserved</p>
      <p class="built-with">Built with Astro + TailwindCSS</p>
    </div>

  </div><!-- /footer-wrap -->
</footer>

<style>
  /* ─── Shell ──────────────────────────────── */
  .footer {
    background: #060D1A;
    position: relative;
    overflow: hidden;
  }

  /* subtle dot-grid texture */
  .footer::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(99,102,241,0.035) 1px, transparent 1px);
    background-size: 30px 30px;
    pointer-events: none;
  }

  /* gradient top rule */
  .footer-rule {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(99,102,241,0.55) 35%,
      rgba(16,185,129,0.45) 65%,
      transparent 100%
    );
  }

  .footer-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 68px 1.5rem 0;
    position: relative;
    z-index: 1;
  }

  /* ─── 4-col grid ─────────────────────────── */
  .footer-grid {
    display: grid;
    grid-template-columns: 1.8fr 1fr 1.4fr 1.6fr;
    gap: 40px 48px;
    padding-bottom: 60px;
    align-items: start;
  }

  .col { display: flex; flex-direction: column; gap: 0; }

  /* ─── Brand col ──────────────────────────── */
  .brand-col { gap: 18px; }

  .brand-logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    width: fit-content;
  }

  .logo-mark {
    width: 40px; height: 40px;
    background: #6366F1;
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Sora', sans-serif;
    font-weight: 700; font-size: 14px; color: #fff;
    flex-shrink: 0;
    transition: box-shadow 0.25s, background 0.25s;
  }
  .brand-logo:hover .logo-mark {
    background: #4F46E5;
    box-shadow: 0 0 0 3px rgba(99,102,241,0.3);
  }

  .logo-name {
    font-family: 'Sora', sans-serif;
    font-weight: 700; font-size: 16px; color: #F8FAFC;
    transition: color 0.2s;
  }
  .brand-logo:hover .logo-name { color: #818CF8; }

  .brand-tagline {
    font-family: 'Inter', sans-serif;
    font-size: 14px; color: #475569;
    line-height: 1.8; max-width: 250px;
  }

  .avail-pill {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(16,185,129,0.08);
    border: 1px solid rgba(16,185,129,0.2);
    border-radius: 100px; padding: 5px 12px;
    font-family: 'Inter', sans-serif;
    font-size: 12px; font-weight: 500; color: #10B981;
    width: fit-content;
  }

  .avail-dot {
    width: 7px; height: 7px;
    background: #10B981; border-radius: 50%;
    flex-shrink: 0;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { box-shadow: 0 0 0 0 rgba(16,185,129,0.45); }
    50%       { box-shadow: 0 0 0 5px rgba(16,185,129,0); }
  }

  .location-row {
    display: flex; align-items: center; gap: 6px;
    font-family: 'Inter', sans-serif;
    font-size: 12px; color: #334155;
  }

  /* ─── Col label ──────────────────────────── */
  .col-label {
    font-family: 'Inter', sans-serif;
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.12em; text-transform: uppercase;
    color: #334155;
    margin-bottom: 18px;
  }

  /* ─── Social col ────────────────────────── */
  .social-col { gap: 0; }

  .social-row {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 16px;
  }

  .social-btn {
    width: 40px; height: 40px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    color: #475569;
    text-decoration: none;
    transition: background 0.2s, border-color 0.2s, color 0.2s, transform 0.2s;
  }
  .social-btn:hover {
    background: rgba(99,102,241,0.14);
    border-color: rgba(99,102,241,0.4);
    color: #818CF8;
    transform: translateY(-2px);
  }

  .email-text-link {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    color: #334155;
    text-decoration: none;
    border-bottom: 1px solid rgba(99,102,241,0.2);
    padding-bottom: 1px;
    transition: color 0.2s, border-color 0.2s;
    word-break: break-all;
  }
  .email-text-link:hover { color: #818CF8; border-color: #6366F1; }

  /* ─── Nav / Services links ───────────────── */
  .links-col nav {
    display: flex; flex-direction: column; gap: 0;
  }

  .footer-link {
    font-family: 'Inter', sans-serif;
    font-size: 14px; color: #475569;
    text-decoration: none;
    padding: 7px 0;
    border-bottom: 1px solid transparent;
    transition: color 0.2s, border-color 0.2s, padding-left 0.2s;
    line-height: 1.4;
  }
  .footer-link:hover {
    color: #F8FAFC;
    border-bottom-color: rgba(99,102,241,0.35);
    padding-left: 4px;
  }

  /* ─── CTA card ───────────────────────────── */
  .cta-col { gap: 0; }

  .cta-card {
    position: relative;
    background: linear-gradient(
      145deg,
      rgba(99,102,241,0.1) 0%,
      rgba(16,185,129,0.05) 100%
    );
    border: 1px solid rgba(99,102,241,0.2);
    border-radius: 14px;
    padding: 26px 22px 22px;
    overflow: hidden;
    transition: border-color 0.3s, box-shadow 0.3s;
  }
  .cta-card:hover {
    border-color: rgba(99,102,241,0.4);
    box-shadow: 0 8px 32px rgba(99,102,241,0.12);
  }

  .card-glow {
    position: absolute;
    top: -50px; right: -50px;
    width: 140px; height: 140px;
    background: radial-gradient(circle, rgba(99,102,241,0.18) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .card-heading {
    font-family: 'Sora', sans-serif;
    font-size: 16px; font-weight: 700;
    color: #F8FAFC; line-height: 1.3;
    margin-bottom: 8px;
    position: relative; z-index: 1;
  }

  .card-sub {
    font-family: 'Inter', sans-serif;
    font-size: 13px; color: #64748B;
    line-height: 1.6;
    margin-bottom: 18px;
    position: relative; z-index: 1;
  }

  .card-btn {
    display: inline-flex; align-items: center; gap: 7px;
    background: #6366F1;
    color: #fff;
    font-family: 'Inter', sans-serif;
    font-weight: 600; font-size: 14px;
    padding: 10px 18px;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
    position: relative; z-index: 1;
    margin-bottom: 12px;
  }
  .card-btn:hover {
    background: #4F46E5;
    transform: translateY(-1px);
    box-shadow: 0 6px 20px rgba(99,102,241,0.4);
  }
  .card-btn svg { transition: transform 0.2s; }
  .card-btn:hover svg { transform: translate(2px,-2px); }

  .card-email {
    font-family: 'Inter', sans-serif;
    font-size: 12px; color: #334155;
    position: relative; z-index: 1;
  }

  .email-link {
    color: #475569; text-decoration: none;
    border-bottom: 1px solid rgba(99,102,241,0.3);
    transition: color 0.2s, border-color 0.2s;
  }
  .email-link:hover { color: #818CF8; border-color: #6366F1; }

  /* ─── Bottom bar ─────────────────────────── */
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.05);
    padding: 18px 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
  }

  .copyright, .built-with {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    color: #1E293B;
  }

  /* ─── Responsive ─────────────────────────── */
  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 36px 48px;
    }
    .brand-col  { grid-column: 1 / -1; }
    .social-col { grid-column: auto; }
    .cta-col    { grid-column: 1 / -1; }
    .cta-card   { max-width: 440px; }
  }

  @media (max-width: 640px) {
    .footer-grid { grid-template-columns: 1fr; gap: 32px; }
    .cta-card    { max-width: 100%; }
    .footer-bottom { flex-direction: column; align-items: center; text-align: center; gap: 6px; }
  }
</style>
