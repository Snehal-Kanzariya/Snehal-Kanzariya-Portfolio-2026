<section id="hero" style="min-height:100vh;display:flex;align-items:center;position:relative;overflow:hidden;padding:120px 1.5rem 80px;">

  <!-- Abstract geometric background -->
  <div class="geo-bg" aria-hidden="true">
    <div class="geo-circle geo-1"></div>
    <div class="geo-circle geo-2"></div>
    <div class="geo-square geo-3"></div>
    <div class="geo-square geo-4"></div>
    <div class="geo-line geo-5"></div>
    <div class="geo-line geo-6"></div>
    <div class="geo-dot-grid"></div>
  </div>

  <div class="hero-inner">

    <!-- Left: Text content -->
    <div class="hero-text">

      <!-- Availability badge -->
      <div class="reveal" style="display:inline-flex;align-items:center;gap:8px;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.25);border-radius:100px;padding:6px 14px;margin-bottom:28px;">
        <span style="width:8px;height:8px;background:#10B981;border-radius:50%;display:inline-block;animation:blink 1.5s ease-in-out infinite;"></span>
        <span style="font-family:'Inter',sans-serif;font-size:13px;font-weight:500;color:#10B981;">Available for new projects</span>
      </div>

      <!-- Headline -->
      <h1 class="reveal delay-100" style="font-family:'Sora',sans-serif;font-size:clamp(34px,4.5vw,58px);font-weight:700;color:#F8FAFC;line-height:1.1;margin-bottom:24px;">
        I build websites that<br />
        <span style="color:#6366F1;">bring customers</span><br />
        to your business.
      </h1>

      <!-- Subheadline -->
      <p class="reveal delay-200" style="font-family:'Inter',sans-serif;font-size:clamp(16px,2vw,19px);color:#94A3B8;line-height:1.65;margin-bottom:40px;max-width:520px;">
        Fast, modern, SEO-ready websites for businesses that want more customers.
        Built in Rajkot. Shipped worldwide.
      </p>

      <!-- CTAs -->
      <div class="reveal delay-300" style="display:flex;flex-wrap:wrap;gap:14px;margin-bottom:28px;">
        <a href="#projects" class="btn-primary cta-pulse">View My Work</a>
        <a href="#contact" class="btn-outline">
          Get in Touch
        </a>
      </div>

      <!-- Pricing badge -->
      <div class="reveal delay-400">
        <span style="display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.1);border-radius:100px;padding:8px 16px;font-family:'Inter',sans-serif;font-size:13px;color:#94A3B8;">
          <span style="color:#10B981;font-weight:600;">Starting at ₹15,000</span>
          <span style="color:rgba(255,255,255,0.2);">·</span>
          <span style="color:#10B981;font-weight:600;">$199 for international clients</span>
        </span>
      </div>

    </div>

    <!-- Right: Photo -->
    <div class="hero-photo reveal delay-200">
      <div class="photo-frame">
        <!-- Glow ring -->
        <div class="photo-glow" aria-hidden="true"></div>
        <!-- Floating accent dots -->
        <div class="accent-dot dot-tl" aria-hidden="true"></div>
        <div class="accent-dot dot-br" aria-hidden="true"></div>

        <img
          src="/assets/snehal.png"
          alt="Snehal Kanzariya — Frontend Developer"
          class="photo-img"
          loading="eager"
        />

        <!-- Status badge floating on image -->
        <div class="photo-badge">
          <span class="badge-dot"></span>
          <span>Open to work</span>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .hero-inner {
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 72px;
    align-items: center;
  }

  .hero-text { display: flex; flex-direction: column; }

  /* ── Buttons ────────────────────────────── */
  .btn-primary {
    background: #6366F1;
    color: #fff;
    padding: 14px 28px;
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 16px;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
    display: inline-block;
  }
  .btn-primary:hover { background: #4F46E5; transform: translateY(-2px); }

  .btn-outline {
    background: transparent;
    color: #F8FAFC;
    padding: 14px 28px;
    border-radius: 8px;
    border: 1.5px solid rgba(99, 102, 241, 0.5);
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 16px;
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s, background 0.2s;
    display: inline-block;
  }
  .btn-outline:hover {
    border-color: #6366F1;
    background: rgba(99, 102, 241, 0.08);
    transform: translateY(-2px);
  }

  /* ── Photo frame ────────────────────────── */
  .hero-photo {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .photo-frame {
    position: relative;
    width: 100%;           /* fills the 360px grid column */
    max-width: 360px;
    animation: floatY 5s ease-in-out infinite;
  }

  @keyframes floatY {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-14px); }
  }

  .photo-glow {
    position: absolute;
    inset: -24px;
    border-radius: 28px;
    background: radial-gradient(ellipse at center, rgba(99,102,241,0.28) 0%, transparent 70%);
    z-index: 0;
    filter: blur(24px);
  }

  .photo-img {
    position: relative;
    z-index: 1;
    width: 100%;
    /* lock 2:3 portrait ratio to match the 1024×1536 source */
    aspect-ratio: 2 / 3;
    object-fit: cover;
    object-position: top center;
    border-radius: 24px;
    display: block;
    box-shadow:
      0 0 0 2px rgba(99, 102, 241, 0.4),
      0 32px 72px rgba(0, 0, 0, 0.55),
      0 8px 24px rgba(99, 102, 241, 0.18);
  }

  /* Floating accent dots */
  .accent-dot {
    position: absolute;
    z-index: 2;
    border-radius: 50%;
  }

  .dot-tl {
    width: 14px; height: 14px;
    background: #6366F1;
    top: -7px; left: -7px;
    box-shadow: 0 0 14px rgba(99, 102, 241, 0.7);
  }

  .dot-br {
    width: 10px; height: 10px;
    background: #10B981;
    bottom: 48px; right: -5px;
    box-shadow: 0 0 10px rgba(16, 185, 129, 0.7);
  }

  /* Floating badge below the photo */
  .photo-badge {
    position: absolute;
    bottom: -20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    align-items: center;
    gap: 8px;
    background: #1E293B;
    border: 1px solid rgba(99, 102, 241, 0.3);
    border-radius: 100px;
    padding: 9px 20px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #F8FAFC;
    white-space: nowrap;
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.45);
  }

  .badge-dot {
    width: 8px; height: 8px;
    background: #10B981;
    border-radius: 50%;
    animation: blink 1.5s ease-in-out infinite;
    flex-shrink: 0;
  }

  /* ── Geometric background ───────────────── */
  .geo-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .geo-circle {
    position: absolute;
    border-radius: 50%;
    border: 1.5px solid;
  }

  .geo-1 {
    width: 480px; height: 480px;
    border-color: rgba(99, 102, 241, 0.08);
    top: -80px; right: -60px;
    animation: slowSpin 40s linear infinite;
  }

  .geo-2 {
    width: 280px; height: 280px;
    border-color: rgba(16, 185, 129, 0.07);
    top: 60px; right: 120px;
    animation: slowSpin 28s linear infinite reverse;
  }

  .geo-square {
    position: absolute;
    border: 1.5px solid;
    border-radius: 12px;
  }

  .geo-3 {
    width: 160px; height: 160px;
    border-color: rgba(99, 102, 241, 0.1);
    top: 180px; right: 80px;
    transform: rotate(45deg);
    animation: slowSpin 20s linear infinite;
  }

  .geo-4 {
    width: 80px; height: 80px;
    border-color: rgba(16, 185, 129, 0.13);
    top: 300px; right: 300px;
    transform: rotate(30deg);
    animation: slowSpin 15s linear infinite reverse;
  }

  .geo-line {
    position: absolute;
    background: linear-gradient(90deg, transparent, rgba(99, 102, 241, 0.15), transparent);
    height: 1px;
  }

  .geo-5 { width: 400px; top: 35%; right: -50px; transform: rotate(-15deg); }
  .geo-6 {
    width: 300px; top: 55%; right: 100px; transform: rotate(10deg);
    background: linear-gradient(90deg, transparent, rgba(16, 185, 129, 0.1), transparent);
  }

  .geo-dot-grid {
    position: absolute;
    top: 80px; right: 0;
    width: 420px; height: 420px;
    background-image: radial-gradient(rgba(99, 102, 241, 0.15) 1px, transparent 1px);
    background-size: 28px 28px;
    mask-image: radial-gradient(ellipse at top right, rgba(0, 0, 0, 0.5) 0%, transparent 65%);
  }

  @keyframes slowSpin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.35; }
  }

  /* ── Responsive ─────────────────────────── */
  @media (max-width: 960px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 52px;
    }
    .hero-photo { order: -1; }
    .photo-frame { max-width: 300px; }
  }

  @media (max-width: 640px) {
    .hero-inner { gap: 40px; }
    .photo-frame { max-width: 240px; }
    .geo-1 { width: 260px; height: 260px; }
    .geo-2 { display: none; }
    .geo-dot-grid { width: 200px; }
  }
</style>
